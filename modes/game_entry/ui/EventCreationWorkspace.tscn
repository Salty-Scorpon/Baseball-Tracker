layout_mode = 2
text = "Event Creation Workspace"

[node name="ModeLabel" type="Label" parent="WorkspaceMargin/WorkspaceScroll/WorkspaceBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Idle"

[node name="SelectedEventLabel" type="Label" parent="WorkspaceMargin/WorkspaceScroll/WorkspaceBox"]
