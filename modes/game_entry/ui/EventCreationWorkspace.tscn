[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://modes/game_entry/ui/EventCreationWorkspace.gd" id="1_workspace"]

[node name="EventCreationWorkspace" type="PanelContainer"]
custom_minimum_size = Vector2(0, 320)
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_workspace")

[node name="WorkspaceMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10

[node name="WorkspaceScroll" type="ScrollContainer" parent="WorkspaceMargin"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
