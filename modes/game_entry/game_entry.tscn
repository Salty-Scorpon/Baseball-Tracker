[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/common/placeholder_screen.gd" id="1_placeholder"]

[node name="GameEntry" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_placeholder")
screen_title = "GameEntry"
description = "Placeholder for live or post-game event entry workflows."

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Content" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="TitleLabel" type="Label" parent="CenterContainer/Content"]
unique_name_in_owner = true
layout_mode = 2
text = "GameEntry"
horizontal_alignment = 1

[node name="DescriptionLabel" type="Label" parent="CenterContainer/Content"]
unique_name_in_owner = true
layout_mode = 2
text = "Placeholder for live or post-game event entry workflows."
horizontal_alignment = 1
autowrap_mode = 3

[node name="BackButton" type="Button" parent="CenterContainer/Content"]
layout_mode = 2
text = "Back to Main Menu"

[connection signal="pressed" from="CenterContainer/Content/BackButton" to="." method="_on_back_button_pressed"]
